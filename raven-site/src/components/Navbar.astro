---
const navLinks = [
  { label: 'Features', href: '#features' },
  { label: 'How it works', href: '#how-it-works' },
  { label: 'Quick Start', href: '#quickstart' },
  { label: 'Docs', href: '/docs' },
];
---

<header class="navbar" id="navbar">
  <div class="container nav-inner">

    <!-- Logo -->
    <a href="/" class="logo" aria-label="Raven home">
      <img src="/raven-icon.svg" width="28" height="28" alt="Raven logo" />
      <span>Raven</span>
    </a>

    <!-- Desktop nav -->
    <nav class="links" aria-label="Primary navigation">
      {navLinks.map(link => (
        <a href={link.href} class="nav-link">{link.label}</a>
      ))}
    </nav>

    <!-- CTA -->
    <div class="nav-cta">
      <a href="https://github.com/rvnhq" class="btn-ghost" target="_blank" rel="noopener">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        GitHub
      </a>
      <a href="/docs" class="btn-primary">Get Started</a>
    </div>

    <!-- Hamburger -->
    <button class="hamburger" id="hamburger" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>

  </div>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <nav>
      {navLinks.map(link => (
        <a href={link.href} class="mobile-link">{link.label}</a>
      ))}
      <a href="/docs" class="btn-primary mobile-cta">Get Started</a>
    </nav>
  </div>
</header>

<style>
.navbar {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(8, 11, 14, 0.8);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--bg-border);
  transition: border-color 0.3s;
}

.navbar.scrolled {
  border-bottom-color: rgba(0, 180, 200, 0.2);
}

.nav-inner {
  display: flex;
  align-items: center;
  height: 68px;
  gap: 2rem;
}

/* Logo */
.logo {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--text-primary);
  flex-shrink: 0;
  transition: opacity 0.2s;
}
.logo:hover { opacity: 0.85; }
.logo span { letter-spacing: -0.01em; }

/* Nav links */
.links {
  display: flex;
  align-items: center;
  gap: 0.25rem;
  margin-left: auto;
}

.nav-link {
  font-size: 0.9rem;
  font-weight: 500;
  color: var(--text-secondary);
  padding: 0.4rem 0.75rem;
  border-radius: var(--radius-sm);
  transition: color 0.2s, background 0.2s;
}
.nav-link:hover {
  color: var(--text-primary);
  background: var(--bg-elevated);
}

/* CTA area */
.nav-cta {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-shrink: 0;
}

.btn-ghost {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--text-secondary);
  padding: 0.4rem 0.75rem;
  border-radius: var(--radius-sm);
  border: var(--border);
  transition: color 0.2s, border-color 0.2s, background 0.2s;
}
.btn-ghost:hover {
  color: var(--text-primary);
  border-color: var(--bg-hover);
  background: var(--bg-elevated);
}

.btn-primary {
  font-size: 0.875rem;
  font-weight: 600;
  color: #001417;
  background: var(--accent);
  padding: 0.45rem 1.1rem;
  border-radius: var(--radius-sm);
  transition: background 0.2s, box-shadow 0.2s, transform 0.15s;
  white-space: nowrap;
}
.btn-primary:hover {
  background: var(--accent-hover);
  box-shadow: var(--accent-glow-sm);
  transform: translateY(-1px);
}

/* Hamburger */
.hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  cursor: pointer;
  background: none;
  border: none;
  padding: 6px;
  margin-left: auto;
}
.hamburger span {
  display: block;
  width: 22px;
  height: 2px;
  background: var(--text-primary);
  border-radius: 2px;
  transition: 0.3s;
}
.hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.hamburger.open span:nth-child(2) { opacity: 0; }
.hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* Mobile menu */
.mobile-menu {
  display: none;
  padding: 1rem 1.5rem 1.5rem;
  border-top: var(--border);
  background: var(--bg-page);
}
.mobile-menu.open { display: block; }
.mobile-link {
  display: block;
  padding: 0.65rem 0;
  font-size: 1rem;
  font-weight: 500;
  color: var(--text-secondary);
  border-bottom: var(--border);
  transition: color 0.2s;
}
.mobile-link:hover { color: var(--accent); }
.mobile-cta {
  display: block;
  margin-top: 1rem;
  text-align: center;
  padding: 0.7rem;
}

@media (max-width: 768px) {
  .links, .nav-cta { display: none; }
  .hamburger { display: flex; }
}
</style>

<script>
const hamburger = document.getElementById('hamburger')!;
const mobileMenu = document.getElementById('mobile-menu')!;
const navbar = document.getElementById('navbar')!;

hamburger.addEventListener('click', () => {
  const isOpen = mobileMenu.classList.toggle('open');
  hamburger.classList.toggle('open', isOpen);
  hamburger.setAttribute('aria-expanded', String(isOpen));
  mobileMenu.setAttribute('aria-hidden', String(!isOpen));
});

// Scrolled state
window.addEventListener('scroll', () => {
  navbar.classList.toggle('scrolled', window.scrollY > 20);
}, { passive: true });
</script>
