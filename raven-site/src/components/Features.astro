---
const features = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
    title: 'Live Metrics',
    description: 'CPU, memory, disk, and network stats streamed in real time from every server in your fleet.',
    accent: 'cyan',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>`,
    title: 'Centralized Logs',
    description: 'Search and filter logs across all servers instantly. No more SSH marathons to find a stack trace.',
    accent: 'cyan',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
    title: 'Smart Alerts',
    description: 'Threshold-based alerting with state transitions. Sends to Discord, Slack, or email — no missed pages.',
    accent: 'violet',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
    title: 'Live Tail',
    description: 'Watch logs streaming in real time via WebSocket. See exactly what\'s happening as it happens.',
    accent: 'cyan',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="9" height="9"/><rect x="13" y="2" width="9" height="9"/><rect x="13" y="13" width="9" height="9"/><rect x="2" y="13" width="9" height="9"/></svg>`,
    title: 'Multi-host',
    description: 'Monitor unlimited servers from one unified dashboard. Add a new host in under a minute.',
    accent: 'violet',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.43"/></svg>`,
    title: 'Offline Resilience',
    description: 'Agents buffer data locally via a Write-Ahead Log when the server is unreachable. No gaps on reconnect.',
    accent: 'cyan',
  },
];
---

<section class="section" id="features">
  <div class="container">

    <div class="section-head">
      <p class="section-label">Features</p>
      <h2 class="section-title">Everything you need to stay on top</h2>
      <p class="section-subtitle">
        Purpose-built for developers who want full visibility without paying Datadog prices.
      </p>
    </div>

    <div class="features-grid">
      {features.map(f => (
        <div class={`feature-card accent-${f.accent}`}>
          <div class="feature-icon" set:html={f.icon} />
          <h3 class="feature-title">{f.title}</h3>
          <p class="feature-desc">{f.description}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
.section-head {
  text-align: center;
  margin-bottom: 3.5rem;
}
.section-subtitle {
  max-width: 520px;
  margin-inline: auto;
}

.features-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.25rem;
}

.feature-card {
  background: var(--bg-card);
  border: var(--border);
  border-radius: var(--radius-lg);
  padding: 1.75rem;
  transition: border-color 0.25s, transform 0.2s, box-shadow 0.25s;
  position: relative;
  overflow: hidden;
}

.feature-card::before {
  content: '';
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity 0.3s;
  border-radius: inherit;
}

.feature-card.accent-cyan::before {
  background: radial-gradient(circle at top left, rgba(0,180,200,0.07), transparent 60%);
}
.feature-card.accent-violet::before {
  background: radial-gradient(circle at top left, rgba(124,111,235,0.07), transparent 60%);
}

.feature-card:hover {
  transform: translateY(-4px);
}
.feature-card.accent-cyan:hover {
  border-color: rgba(0,180,200,0.35);
  box-shadow: 0 20px 40px rgba(0,0,0,0.3), 0 0 30px rgba(0,180,200,0.06);
}
.feature-card.accent-violet:hover {
  border-color: rgba(124,111,235,0.35);
  box-shadow: 0 20px 40px rgba(0,0,0,0.3), 0 0 30px rgba(124,111,235,0.06);
}
.feature-card:hover::before { opacity: 1; }

.feature-icon {
  width: 40px; height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  margin-bottom: 1rem;
  position: relative;
}
.accent-cyan .feature-icon {
  color: var(--accent);
  background: var(--accent-soft);
}
.accent-violet .feature-icon {
  color: var(--violet);
  background: var(--violet-soft);
}

.feature-title {
  font-size: 1rem;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 0.5rem;
}

.feature-desc {
  font-size: 0.9rem;
  color: var(--text-secondary);
  line-height: 1.65;
}

@media (max-width: 1024px) {
  .features-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 640px) {
  .features-grid { grid-template-columns: 1fr; }
}
</style>
