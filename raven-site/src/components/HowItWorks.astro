---
const steps = [
  {
    number: '01',
    title: 'Install the Agent',
    description: 'Drop the lightweight Rust agent on any Linux server. It starts collecting CPU, memory, disk, network, and logs immediately.',
    code: 'curl -sSL https://get.ravenmon.io | sh',
    detail: '~12MB binary · zero dependencies',
  },
  {
    number: '02',
    title: 'Stream via gRPC',
    description: 'Metrics and logs are batched and sent securely to your Raven server over gRPC. TLS encrypted. WAL-buffered for resilience.',
    code: 'raven-agent --server https://your-raven:443',
    detail: 'TLS · Auth tokens · Reconnection',
  },
  {
    number: '03',
    title: 'View your Dashboard',
    description: 'Real-time charts, searchable logs, and live tail — all from one clean dashboard. Set alert rules and get notified instantly.',
    code: 'docker compose up -d',
    detail: 'VictoriaMetrics · ClickHouse · Astro UI',
  },
];
---

<section class="section how" id="how-it-works">
  <div class="how-bg" aria-hidden="true">
    <div class="how-glow"></div>
  </div>

  <div class="container">

    <div class="section-head">
      <p class="section-label">How it works</p>
      <h2 class="section-title">Up and running in minutes</h2>
      <p class="section-subtitle">
        Three steps to full visibility. No cloud accounts. No configuration sprawl.
      </p>
    </div>

    <div class="steps">
      {steps.map((step, i) => (
        <div class="step">

          <!-- Connector line -->
          {i < steps.length - 1 && (
            <div class="connector" aria-hidden="true">
              <div class="connector-line"></div>
              <div class="connector-arrow">›</div>
            </div>
          )}

          <div class="step-card">
            <div class="step-num">{step.number}</div>
            <h3 class="step-title">{step.title}</h3>
            <p class="step-desc">{step.description}</p>
            <div class="step-code">
              <code>{step.code}</code>
            </div>
            <p class="step-detail">{step.detail}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
.how {
  position: relative;
  overflow: hidden;
}

.how-bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
}
.how-glow {
  position: absolute;
  width: 800px; height: 400px;
  left: 50%; top: 50%;
  transform: translate(-50%, -50%);
  background: radial-gradient(ellipse, rgba(0,180,200,0.05) 0%, transparent 70%);
}

.section-head {
  text-align: center;
  margin-bottom: 4rem;
}
.section-subtitle { max-width: 520px; margin-inline: auto; }

.steps {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  position: relative;
  align-items: start;
}

.step {
  position: relative;
}

.connector {
  position: absolute;
  top: 60px;
  right: -24px;
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 4px;
}
.connector-line {
  width: 30px;
  height: 1px;
  background: linear-gradient(90deg, var(--bg-border), rgba(0,180,200,0.4));
}
.connector-arrow {
  color: var(--accent);
  font-size: 1.1rem;
  line-height: 1;
  opacity: 0.7;
}

.step-card {
  background: var(--bg-card);
  border: var(--border);
  border-radius: var(--radius-lg);
  padding: 2rem;
  margin: 0 0.75rem;
  transition: border-color 0.25s, box-shadow 0.25s, transform 0.2s;
  position: relative;
  overflow: hidden;
}
.step-card::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, var(--accent), var(--violet));
  opacity: 0;
  transition: opacity 0.3s;
}
.step-card:hover {
  border-color: rgba(0,180,200,0.3);
  transform: translateY(-4px);
  box-shadow: 0 24px 48px rgba(0,0,0,0.3);
}
.step-card:hover::after { opacity: 1; }

.step-num {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  font-weight: 600;
  color: var(--accent);
  background: var(--accent-soft);
  border: 1px solid rgba(0,180,200,0.2);
  padding: 3px 9px;
  border-radius: 999px;
  display: inline-block;
  margin-bottom: 1.1rem;
  letter-spacing: 0.06em;
}

.step-title {
  font-size: 1.1rem;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 0.6rem;
}

.step-desc {
  font-size: 0.88rem;
  color: var(--text-secondary);
  line-height: 1.65;
  margin-bottom: 1.25rem;
}

.step-code {
  background: var(--bg-page);
  border: var(--border);
  border-radius: var(--radius-sm);
  padding: 0.65rem 0.9rem;
  margin-bottom: 0.75rem;
  overflow-x: auto;
}
.step-code code {
  font-family: var(--font-mono);
  font-size: 0.76rem;
  color: var(--accent);
  background: none;
  border: none;
  padding: 0;
  white-space: nowrap;
}

.step-detail {
  font-size: 0.75rem;
  color: var(--text-muted);
  font-family: var(--font-mono);
}

@media (max-width: 900px) {
  .steps {
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  .connector { display: none; }
  .step-card { margin: 0; }
}
</style>
