---
---

<section class="hero" id="hero">

  <!-- Background effects -->
  <div class="hero-bg" aria-hidden="true">
    <div class="glow glow-1"></div>
    <div class="glow glow-2"></div>
    <div class="grid-overlay"></div>
  </div>

  <div class="container hero-inner">

    <!-- Badge -->
    <div class="hero-badge">
      <span class="badge-dot"></span>
      Open source · Self-hosted · No vendor lock-in
    </div>

    <!-- Heading -->
    <h1 class="hero-title">
      Observe everything.<br />
      <span class="accent-text">Own your data.</span>
    </h1>

    <p class="hero-subtitle">
      Raven is a lightweight, self-hosted monitoring platform.
      Real-time metrics, centralized logs, and smart alerts —
      all in one dashboard, on your own infrastructure.
    </p>

    <!-- CTAs -->
    <div class="hero-actions">
      <a href="/docs" class="cta-primary">
        Get Started
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="https://github.com/rvnhq" class="cta-secondary" target="_blank" rel="noopener">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        Star on GitHub
      </a>
    </div>

    <!-- Stats row -->
    <div class="hero-stats">
      <div class="stat">
        <span class="stat-value">~12MB</span>
        <span class="stat-label">Agent binary</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat">
        <span class="stat-value">&lt;5s</span>
        <span class="stat-label">Metric latency</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat">
        <span class="stat-value">gRPC</span>
        <span class="stat-label">Transport</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat">
        <span class="stat-value">∞</span>
        <span class="stat-label">Servers</span>
      </div>
    </div>

  </div>

  <!-- Terminal preview -->
  <div class="container terminal-wrap">
    <div class="terminal" role="img" aria-label="Raven live logs terminal preview">
      <div class="terminal-bar">
        <div class="dot red"></div>
        <div class="dot yellow"></div>
        <div class="dot green"></div>
        <span class="terminal-title">raven · live logs</span>
      </div>
      <div class="terminal-body" id="terminal-body">
        <div class="log-line"><span class="log-time">09:41:02</span> <span class="log-info">[INFO]</span> <span class="log-svc">agent/metrics</span> cpu=12.4% mem=41.2% disk=58% net_rx=1.2MB</div>
        <div class="log-line"><span class="log-time">09:41:03</span> <span class="log-info">[INFO]</span> <span class="log-svc">server/ingest</span> received batch agents=3 metrics=288</div>
        <div class="log-line"><span class="log-time">09:41:04</span> <span class="log-warn">[WARN]</span> <span class="log-svc">agent/disk</span> usage=91% path=/var/log threshold=90%</div>
        <div class="log-line"><span class="log-time">09:41:05</span> <span class="log-info">[INFO]</span> <span class="log-svc">agent/metrics</span> cpu=14.1% mem=42.0% disk=91% net_rx=980KB</div>
        <div class="log-line"><span class="log-time">09:41:06</span> <span class="log-error">[ERROR]</span> <span class="log-svc">alerts/engine</span> fired rule="disk_critical" node="prod-01" severity=high</div>
        <div class="log-line"><span class="log-time">09:41:06</span> <span class="log-info">[INFO]</span> <span class="log-svc">alerts/discord</span> notification sent channel=#ops-alerts</div>
        <div class="log-line"><span class="log-time">09:41:07</span> <span class="log-info">[INFO]</span> <span class="log-svc">server/ws</span> broadcast log_batch lines=12 subscribers=2</div>
        <div class="log-line log-new"><span class="log-time">09:41:08</span> <span class="log-info">[INFO]</span> <span class="log-svc">agent/heartbeat</span> ping node="prod-02" latency=4ms <span class="cursor">▍</span></div>
      </div>
    </div>
  </div>

</section>

<style>
.hero {
  position: relative;
  padding: 120px 0 80px;
  overflow: hidden;
  text-align: center;
}

/* ── Background ── */
.hero-bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 0;
}

.glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
}
.glow-1 {
  width: 600px; height: 600px;
  top: -200px; left: -100px;
  background: radial-gradient(circle, rgba(0,180,200,0.18) 0%, transparent 70%);
  animation: float1 8s ease-in-out infinite;
}
.glow-2 {
  width: 500px; height: 500px;
  top: -150px; right: -80px;
  background: radial-gradient(circle, rgba(124,111,235,0.14) 0%, transparent 70%);
  animation: float2 10s ease-in-out infinite;
}

@keyframes float1 {
  0%,100% { transform: translate(0,0); }
  50% { transform: translate(30px, 20px); }
}
@keyframes float2 {
  0%,100% { transform: translate(0,0); }
  50% { transform: translate(-20px, 30px); }
}

.grid-overlay {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(0,180,200,0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,180,200,0.04) 1px, transparent 1px);
  background-size: 48px 48px;
  mask-image: radial-gradient(ellipse 80% 60% at 50% 0%, black 0%, transparent 100%);
}

/* ── Content ── */
.hero-inner {
  position: relative;
  z-index: 1;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.78rem;
  font-weight: 500;
  color: var(--text-secondary);
  background: var(--bg-elevated);
  border: var(--border);
  padding: 0.35rem 0.9rem;
  border-radius: 999px;
  margin-bottom: 1.75rem;
  letter-spacing: 0.02em;
}

.badge-dot {
  width: 7px; height: 7px;
  background: var(--accent);
  border-radius: 50%;
  box-shadow: 0 0 8px var(--accent);
  animation: pulse-dot 2s ease-in-out infinite;
}
@keyframes pulse-dot {
  0%,100% { box-shadow: 0 0 6px var(--accent); }
  50% { box-shadow: 0 0 14px var(--accent); }
}

.hero-title {
  font-size: clamp(2.6rem, 6vw, 4.2rem);
  font-weight: 700;
  line-height: 1.1;
  letter-spacing: -0.03em;
  color: var(--text-primary);
}

.accent-text {
  background: linear-gradient(135deg, var(--accent) 0%, var(--violet) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-subtitle {
  margin-top: 1.25rem;
  font-size: 1.1rem;
  color: var(--text-secondary);
  max-width: 560px;
  margin-inline: auto;
  line-height: 1.65;
}

/* ── CTAs ── */
.hero-actions {
  display: flex;
  justify-content: center;
  gap: 0.75rem;
  margin-top: 2.25rem;
  flex-wrap: wrap;
}

.cta-primary {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.95rem;
  font-weight: 600;
  color: #001417;
  background: var(--accent);
  padding: 0.7rem 1.4rem;
  border-radius: var(--radius-md);
  box-shadow: var(--accent-glow-sm);
  transition: background 0.2s, box-shadow 0.2s, transform 0.15s;
}
.cta-primary:hover {
  background: var(--accent-hover);
  box-shadow: var(--accent-glow);
  transform: translateY(-2px);
}

.cta-secondary {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.95rem;
  font-weight: 500;
  color: var(--text-primary);
  background: var(--bg-elevated);
  border: var(--border);
  padding: 0.7rem 1.4rem;
  border-radius: var(--radius-md);
  transition: border-color 0.2s, background 0.2s, transform 0.15s;
}
.cta-secondary:hover {
  border-color: rgba(0,180,200,0.35);
  background: var(--bg-hover);
  transform: translateY(-2px);
}

/* ── Stats ── */
.hero-stats {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 2rem;
  margin-top: 3rem;
  flex-wrap: wrap;
}

.stat {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}

.stat-value {
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--text-primary);
  font-family: var(--font-mono);
}

.stat-label {
  font-size: 0.75rem;
  color: var(--text-muted);
  letter-spacing: 0.04em;
}

.stat-divider {
  width: 1px;
  height: 32px;
  background: var(--bg-border);
}

/* ── Terminal ── */
.terminal-wrap {
  position: relative;
  z-index: 1;
  margin-top: 4rem;
  max-width: 800px;
}

.terminal {
  background: var(--bg-card);
  border: var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow:
    0 0 0 1px rgba(0,180,200,0.08),
    0 40px 80px rgba(0,0,0,0.5),
    0 0 60px rgba(0,180,200,0.06);
  text-align: left;
}

.terminal-bar {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.75rem 1rem;
  background: var(--bg-elevated);
  border-bottom: var(--border);
}

.dot {
  width: 11px; height: 11px;
  border-radius: 50%;
}
.dot.red    { background: #FF5F57; }
.dot.yellow { background: #FFBD2E; }
.dot.green  { background: #28CA41; }

.terminal-title {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  color: var(--text-muted);
  margin-left: 0.25rem;
}

.terminal-body {
  padding: 1.25rem 1.5rem;
  font-family: var(--font-mono);
  font-size: 0.78rem;
  line-height: 1.9;
  background: var(--bg-card);
  overflow-x: auto;
}

.log-line {
  white-space: nowrap;
  opacity: 0;
  animation: log-appear 0.3s ease forwards;
}
.log-line:nth-child(1) { animation-delay: 0.1s; }
.log-line:nth-child(2) { animation-delay: 0.3s; }
.log-line:nth-child(3) { animation-delay: 0.55s; }
.log-line:nth-child(4) { animation-delay: 0.8s; }
.log-line:nth-child(5) { animation-delay: 1.1s; }
.log-line:nth-child(6) { animation-delay: 1.35s; }
.log-line:nth-child(7) { animation-delay: 1.6s; }
.log-line:nth-child(8) { animation-delay: 1.85s; }

@keyframes log-appear {
  from { opacity: 0; transform: translateX(-4px); }
  to   { opacity: 1; transform: translateX(0); }
}

.log-time  { color: var(--text-muted); }
.log-info  { color: var(--accent); }
.log-warn  { color: var(--warning); }
.log-error { color: var(--danger); }
.log-svc   { color: var(--violet); }

.cursor {
  color: var(--accent);
  animation: blink 1s step-end infinite;
}
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

@media (max-width: 768px) {
  .hero { padding: 80px 0 60px; }
  .hero-stats { gap: 1.25rem; }
  .stat-divider { display: none; }
  .terminal-body { font-size: 0.7rem; }
}
</style>
